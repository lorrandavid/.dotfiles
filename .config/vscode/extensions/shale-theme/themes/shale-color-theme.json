  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5c7265",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "keyword.operator.expression",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.void",
        "keyword.operator.of",
        "keyword.operator.in"
      ],
      "settings": {
        "foreground": "#c97fa0"
      }
    },
    {
      "name": "Storage / Variable Declaration",
      "scope": [
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#c97fa0"
      }
    },
    {
      "name": "Storage Type Keyword (function)",
      "scope": [
        "storage.type.function"
      ],
      "settings": {
        "foreground": "#c97fa0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type-defining Keywords (class, interface, enum, type, namespace)",
      "scope": [
        "storage.type.class",
        "storage.type.interface",
        "storage.type.enum",
        "storage.type.type",
        "storage.type.namespace"
      ],
      "settings": {
        "foreground": "#d4a96a"
      }
    },
    {
      "name": "Storage Modifier (public, private, static, async, etc.)",
      "scope": [
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d4a96a"
      }
    },
    {
      "name": "Return Keyword",
      "scope": [
        "keyword.control.return",
        "keyword.control.flow.return"
      ],
      "settings": {
        "foreground": "#c97fa0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#a8c97f"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#7fb4c9"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#d4a96a"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.language",
        "support.constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#9ed490"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#e8956d"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean",
        "constant.language.true",
        "constant.language.false"
      ],
      "settings": {
        "foreground": "#9ed490"
      }
    },
    {
      "name": "Null / Undefined",
      "scope": [
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nil"
      ],
      "settings": {
        "foreground": "#9ed490"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.bitwise",
        "keyword.operator.increment",
        "keyword.operator.decrement",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.type",
        "keyword.operator.optional"
      ],
      "settings": {
        "foreground": "#b0c9be"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#d6e0d8"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "variable.other.jsdoc"
      ],
      "settings": {
        "foreground": "#c9b97f"
      }
    },
    {
      "name": "Property / Member",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#9ec4d4"
      }
    },
    {
      "name": "Variable Builtin (this, self, super)",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#c97fa0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tag (HTML/JSX)",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#c97fa0"
      }
    },
    {
      "name": "Tag Punctuation",
      "scope": [
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#b0c9be"
      }
    },
    {
      "name": "Tag Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#d4a96a"
      }
    },
    {
      "name": "Punctuation Bracket",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#8a9e91"
      }
    },
    {
      "name": "Punctuation Delimiter",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#b0c9be"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "keyword.operator.quantifier.regexp",
        "keyword.operator.or.regexp",
        "keyword.operator.negation.regexp",
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp"
      ],
      "settings": {
        "foreground": "#e8956d"
      }
    },
    {
      "name": "Escape Character",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#e8956d"
      }
    },
    {
      "name": "Template Expression Punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.quasi"
      ],
      "settings": {
        "foreground": "#e8956d"
      }
    },
    {
      "name": "Module / Namespace",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.other.module"
      ],
      "settings": {
        "foreground": "#d4a96a"
      }
    },
    {
      "name": "Decorator / Attribute",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#d4a96a"
      }
    },
    {
      "name": "Constructor",
      "scope": [
        "entity.name.function.constructor",
        "support.class.constructor"
      ],
      "settings": {
        "foreground": "#d4a96a"
      }
    },
    {
      "name": "Support Function Builtin",
      "scope": [
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#9ed490",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSON Property",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#9ec4d4"
      }
    },
    {
      "name": "YAML Key",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#9ec4d4"
      }
    },
    {
      "name": "TOML Key",
      "scope": [
        "keyword.key.toml",
        "support.type.property-name.toml"
      ],
      "settings": {
        "foreground": "#9ec4d4"
      }
    },
    {
      "name": "TOML Table",
      "scope": [
        "entity.name.table.toml",
        "support.type.property-name.table.toml"
      ],
      "settings": {
        "foreground": "#d4a96a"
      }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#9ec4d4"
      }
    },
    {
      "name": "CSS Value",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#d6e0d8"
      }
    },
    {
      "name": "CSS Selector (class/id)",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
